 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🔍 Querying the Knowledge Base\n",
    "\n",
    "This notebook demonstrates how to query the RAG knowledge base directly and\n",
    "test the response quality. You can use this to:\n",
    "- Verify documents were indexed correctly\n",
    "- Compare RAG-augmented vs. non-RAG responses\n",
    "- Debug search relevance by examining scored results\n",
    "- Test edge cases and query variations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import json\n",
    "\n",
    "# ── Configuration ──\n",
    "API_BASE = \"http://localhost:8000\"\n",
    "\n",
    "# Replace with your credentials\n",
    "USERNAME = \"testuser\"\n",
    "PASSWORD = \"password123\"\n",
    "\n",
    "# Login\n",
    "resp = requests.post(f\"{API_BASE}/auth/login\",\n",
    "                     json={\"username\": USERNAME, \"password\": PASSWORD})\n",
    "resp.raise_for_status()\n",
    "token = resp.json()[\"access_token\"]\n",
    "headers = {\"Authorization\": f\"Bearer {token}\"}\n",
    "print(f\"✅ Logged in. Token: {token[:20]}...\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Query Function"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def query_kb(query: str, top_k: int = 5, verbose: bool = True) -> dict:\n",
    "    \"\"\"Query the knowledge base and optionally print results.\"\"\"\n",
    "    resp = requests.post(\n",
    "        f\"{API_BASE}/rag/query\",\n",
    "        headers=headers,\n",
    "        json={\"query\": query, \"top_k\": top_k},\n",
    "    )\n",
    "\n",
    "    if resp.status_code == 422:\n",
    "        print(f\"❌ Guardrail blocked the query\")\n",
    "        print(json.dumps(resp.json(), indent=2))\n",
    "        return {}\n",
    "\n",
    "    resp.raise_for_status()\n",
    "    data = resp.json()\n",
    "\n",
    "    if verbose:\n",
    "        print(f\"🔍 Query: '{query}'\")\n",
    "        print(f\"📊 Found {len(data['sources'])} relevant passages\")\n",
    "        print()\n",
    "        for i, src in enumerate(data['sources'], 1):\n",
    "            print(f\"─── Result #{i} ───\")\n",
    "            print(f\"   📄 Source: {src['source']}\")\n",
    "            print(f"   🎯 Score:    {src['score']:.4f}\")\n",
    "            print(f\"   📝 Preview:  {src['content'][:200]}...\")\n",
    "            print()\n",
    "\n",
    "    return data\n",
    "\n",
    "\n",
    "print(\"✅ Query function ready. Call query_kb('your question here')\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Test Queries\n",
    "\n",
    "Try these example queries after indexing some documents:"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run this cell to test a basic query\n",
    "result = query_kb(\"What information is available in the knowledge base?\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Compare Queries at Different top_k Values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "query = \"key findings\"  # Change this to match your documents\n",
    "\n",
    "for k in [1, 3, 5, 10]:\n",
    "    data = query_kb(query, top_k=k, verbose=False)\n",
    "    if data.get(\"sources\"):\n",
    "        scores = [s[\"score\"] for s in data[\"sources\"]]\n",
    "        print(f\"top_k={k:2d} → {len(data['sources'])} results, scores: {[round(s, 3) for s in scores]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Complete Chat Flow (RAG + Agent)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def chat_with_agent(message: str) -> dict:\n",
    "    \"\"\"Send a message to the AI agent (includes RAG context automatically).\"\"\"\n",
    "    resp = requests.post(\n",
    "        f\"{API_BASE}/chat/message\",\n",
    "        headers=headers,\n",
    "        json={\"message\": message},\n",
    "    )\n",
    "\n",
    "    if resp.status_code == 422:\n",
    "        print(f\"❌ Guardrail blocked\")\n",
    "        return resp.json()\n",
    "\n",
    "    resp.raise_for_status()\n",
    "    return resp.json()\n",
    "\n",
    "\n",
    "# Test the chat flow\n",
    "response = chat_with_agent(\"What can you tell me about the data we have?\")\n",
    "print(f\"🤖 Agent: {response.get('agent', 'unknown')}\")\n",
    "print(f\"🔄 Path: {' → '.join(response.get('routing_path', []))}\")\n",
    "print(f\"\\n💬 Reply:\\n{response.get('reply', 'No response')[:500]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Score Distribution Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def analyze_results(query: str) -> None:\n",
    "    \"\"\"Analyze how well the RAG system retrieves for a given query.\"\"\"\n",
    "    data = query_kb(query, top_k=10, verbose=False)\n",
    "    sources = data.get(\"sources\", [])\n",
    "\n",
    "    if not sources:\n",
    "        print(f\"❌ No results for: '{query}'\")\n",
    "        return\n",
    "\n",
    "    scores = [s[\"score\"] for s in sources]\n",
    "    sources_list = [s[\"source\"] for s in sources]\n",
    "\n",
    "    print(f\"Query: '{query}'\")\n",
    "    print(f\"Total results: {len(scores)}\")\n",
    "    print(f\"Score range:   {min(scores):.4f} - {max(scores):.4f}\")\n",
    "    print(f\"Average score: {sum(scores)/len(scores):.4f}\")\n",
    "    print(f\"Unique sources: {len(set(sources_list))}\")\n",
    "    print(f\"Score distribution:\")\n",
    "    for i, s in enumerate(sources):\n",
    "        bar = \"█\" * int(s[\"score\"] * 50)\n",
    "        print(f\"  #{i+1}: {s['score']:.4f} {bar} [{s['source'][:30]}]\")\n",
    "\n",
    "\n",
    "# Run analysis\n",
    "analyze_results(\"summary of our data\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Guardrail Test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def test_guardrail(text: str) -> dict:\n",
    "    \"\"\"Test the guardrail directly.\"\"\"\n",
    "    resp = requests.post(f\"{API_BASE}/guardrail/check?text={text}\")\n",
    "    return resp.json()\n",
    "\n",
    "\n",
    "# Test a safe query\n",
    "print(\"🔒 Testing guardrail with safe text...\")\n",
    "print(test_guardrail(\"What is machine learning?\"))\n",
    "print()\n",
    "\n",
    "# Test a blocked query\n",
    "print(\"🚫 Testing guardrail with PII...\")\n",
    "print(test_guardrail(\"My SSN is 123-45-6789\"))"
   ]
  }
